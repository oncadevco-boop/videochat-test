# Frontend Configuration
# Reemplaza los hostnames con los de tus Dev Tunnels activos

# Dev Tunnels (recomendado para pruebas remotas)
NEXT_PUBLIC_API_URL=https://TU-TUNNEL-3001.use2.devtunnels.ms/api
NEXT_PUBLIC_PEER_SERVER_URL=https://TU-TUNNEL-9000.use2.devtunnels.ms/peerjs

# TURN — obligatorio para que el video funcione entre redes distintas
# Opción gratuita para desarrollo (OpenRelay):
NEXT_PUBLIC_TURN_URLS=turn:openrelay.metered.ca:80,turn:openrelay.metered.ca:443,turn:openrelay.metered.ca:443?transport=tcp
NEXT_PUBLIC_TURN_USERNAME=openrelayproject
NEXT_PUBLIC_TURN_CREDENTIAL=openrelayproject

# URL del frontend tunneled (solo referencia — ábrela en el navegador):
# https://TU-TUNNEL-3000.use2.devtunnels.ms
